@page "/"
@model IndexModel
@{
    ViewData["Title"] = "prd-to-prod — autonomous software delivery";
    ViewData["NavTitle"] = "PRD-TO-PROD";
}

@section Head {
    <meta name="description" content="PRD to deployed code. No human in the loop. Autonomous delivery pipeline powered by gh-aw." />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="prd-to-prod" />
    <meta property="og:url" content="https://prd-to-prod.azurewebsites.net" />
    <meta property="og:title" content="prd-to-prod — autonomous software delivery" />
    <meta property="og:description" content="PRD to deployed code. No human in the loop." />
    <meta property="og:image" content="https://prd-to-prod.azurewebsites.net/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="prd-to-prod — autonomous software delivery" />
    <meta name="twitter:description" content="PRD to deployed code. No human in the loop." />
    <meta name="twitter:image" content="https://prd-to-prod.azurewebsites.net/og-image.png" />
}

@section Styles {
<style>
    /* Hero layout */
    .hero-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 48px;
        align-items: start;
        padding: 64px 0 40px;
    }
    @@media (min-width: 768px) {
        .hero-grid {
            grid-template-columns: 3fr 2fr;
        }
    }

    .hero-headline {
        font-family: var(--mono);
        font-size: clamp(1.6rem, 3.5vw, 2rem);
        font-weight: 700;
        color: var(--text);
        line-height: 1.2;
        letter-spacing: -0.01em;
        margin-bottom: 16px;
    }

    .hero-sub {
        color: var(--dim);
        font-family: var(--sans);
        font-size: 0.875rem;
        line-height: 1.6;
        max-width: 520px;
        margin-bottom: 12px;
    }
    .hero-sub:last-of-type {
        margin-bottom: 28px;
    }
    .hero-sub a {
        color: var(--accent);
        text-decoration: none;
    }
    .hero-sub a:hover {
        text-decoration: underline;
    }

    .hero-ctas {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }
    .hero-cta-primary {
        display: inline-flex;
        align-items: center;
        font-family: var(--mono);
        font-size: 0.8rem;
        font-weight: 600;
        padding: 12px 24px;
        border: 1px solid var(--accent);
        color: var(--bg);
        background: var(--accent);
        text-decoration: none;
        transition: background 0.15s, border-color 0.15s;
        letter-spacing: 0.03em;
    }
    .hero-cta-primary:hover {
        background: #79c0ff;
        border-color: #79c0ff;
    }
    .hero-cta-secondary {
        display: inline-flex;
        align-items: center;
        font-family: var(--mono);
        font-size: 0.8rem;
        font-weight: 600;
        padding: 12px 24px;
        border: 1px solid var(--border);
        color: var(--dim);
        background: transparent;
        text-decoration: none;
        transition: border-color 0.15s, color 0.15s;
        letter-spacing: 0.03em;
    }
    .hero-cta-secondary:hover {
        border-color: var(--accent);
        color: var(--text);
    }

    /* Pipeline schematic */
    .pipeline-schematic {
        display: flex;
        flex-direction: column;
        font-family: var(--mono);
        font-size: 0.7rem;
    }
    .pipeline-stage {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        border: 1px solid var(--border);
        border-bottom: none;
        background: rgba(22, 27, 34, 0.6);
        transition: border-color 0.2s;
    }
    .pipeline-stage:last-child {
        border-bottom: 1px solid var(--border);
    }
    .pipeline-stage:hover {
        border-color: rgba(88, 166, 255, 0.3);
    }
    .pipeline-stage:hover + .pipeline-stage {
        border-top-color: rgba(88, 166, 255, 0.3);
    }
    .pipeline-num {
        color: var(--border);
        font-size: 0.6rem;
        font-weight: 700;
        width: 16px;
        flex-shrink: 0;
    }
    .pipeline-name {
        color: var(--text);
        font-weight: 600;
        flex-shrink: 0;
        min-width: 90px;
    }
    .pipeline-arrow {
        color: var(--border);
        flex-shrink: 0;
    }
    .pipeline-desc {
        color: var(--dim);
        font-size: 0.65rem;
    }

    /* Evidence line */
    .evidence-line {
        font-family: var(--mono);
        font-size: 0.75rem;
        color: var(--dim);
        padding: 14px 0;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        letter-spacing: 0.02em;
        margin-bottom: 40px;
    }
    .evidence-line strong {
        color: #79c0ff;
        font-weight: 700;
    }

    /* Callout cards (shared structure) */
    .callout-card {
        background: #161b22;
        border: 1px solid var(--border);
        padding: 20px 24px;
        margin-bottom: 40px;
    }
    .callout-card-label {
        font-family: var(--mono);
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }
    .callout-card-title {
        font-family: var(--mono);
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 4px;
    }
    .callout-card-desc {
        color: var(--dim);
        font-size: 0.8rem;
        line-height: 1.5;
    }
    .callout-card-links {
        margin-top: 12px;
        display: flex;
        gap: 16px;
    }
    .callout-card-links a {
        font-family: var(--mono);
        font-size: 0.7rem;
        text-decoration: none;
        transition: color 0.15s;
    }
    .callout-card-links a:hover {
        color: var(--text);
    }

    /* Boundary stop variant */
    .callout-boundary {
        border-left: 3px solid var(--red);
    }
    .callout-boundary .callout-card-label {
        color: var(--red);
    }
    .callout-boundary .boundary-summary {
        font-family: var(--sans);
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--text);
        line-height: 1.4;
        margin-bottom: 10px;
    }
    .callout-boundary .boundary-meta {
        font-family: var(--mono);
        font-size: 0.7rem;
        color: var(--dim);
        line-height: 1.6;
    }
    .callout-boundary .boundary-meta span {
        color: var(--red);
    }
    .callout-boundary .callout-card-links a {
        color: var(--dim);
    }

    /* Integration variant */
    .callout-integration {
        border-left: 3px solid var(--accent);
    }
    .callout-integration .callout-card-label {
        color: var(--accent);
    }
    .callout-integration .callout-card-links a {
        color: var(--accent);
    }

    /* Footer */
    .landing-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 0;
        border-top: 1px solid var(--border);
        font-size: 0.7rem;
        color: var(--dim);
        flex-wrap: wrap;
        gap: 12px;
    }
    .landing-footer a {
        color: var(--dim);
        text-decoration: none;
        transition: color 0.15s;
    }
    .landing-footer a:hover {
        color: var(--text);
    }
    .footer-links {
        display: flex;
        gap: 16px;
    }

    /* Reduced motion */
    @@media (prefers-reduced-motion: reduce) {
        .pipeline-stage,
        .hero-cta-primary,
        .hero-cta-secondary,
        .callout-card-links a,
        .landing-footer a {
            transition: none;
        }
    }
</style>
}

<div style="max-width: 1100px; margin: 0 auto; padding: 0 24px;">

    <!-- Hero -->
    <section class="hero-grid" aria-labelledby="hero-heading">
        <div>
            <h1 id="hero-heading" class="hero-headline">
                PRD to deployed code.<br />No human in the loop.
            </h1>
            <p class="hero-sub">
                An autonomous delivery pipeline powered by
                <a href="https://github.com/github/gh-aw" target="_blank" rel="noopener noreferrer">gh-aw</a>.
                Write a product spec as a GitHub issue. AI agents decompose, implement,
                review, and ship it — while humans keep control over policy and what the
                system is allowed to do.
            </p>
            <p class="hero-sub">
                The interesting part is not code generation. It is the full operating
                loop and the explicit place where the system stops.
            </p>
            <div class="hero-ctas">
                <a href="/pipeline" class="hero-cta-primary">View Pipeline</a>
                <a href="https://github.com/samuelkahessay/prd-to-prod" target="_blank" rel="noopener noreferrer" class="hero-cta-secondary">GitHub</a>
            </div>
        </div>

        <div class="pipeline-schematic" aria-label="Pipeline stages">
            <div class="pipeline-stage">
                <span class="pipeline-num">01</span>
                <span class="pipeline-name" style="color: var(--accent);">INPUT</span>
                <span class="pipeline-arrow">&#8594;</span>
                <span class="pipeline-desc">Human intent + acceptance criteria</span>
            </div>
            <div class="pipeline-stage">
                <span class="pipeline-num">02</span>
                <span class="pipeline-name">DECOMPOSE</span>
                <span class="pipeline-arrow">&#8594;</span>
                <span class="pipeline-desc">Break spec into ordered sub-issues</span>
            </div>
            <div class="pipeline-stage">
                <span class="pipeline-num">03</span>
                <span class="pipeline-name">IMPLEMENT</span>
                <span class="pipeline-arrow">&#8594;</span>
                <span class="pipeline-desc">Write code, open PRs</span>
            </div>
            <div class="pipeline-stage">
                <span class="pipeline-num">04</span>
                <span class="pipeline-name">REVIEW</span>
                <span class="pipeline-arrow">&#8594;</span>
                <span class="pipeline-desc">Diff against spec and policy</span>
            </div>
            <div class="pipeline-stage">
                <span class="pipeline-num">05</span>
                <span class="pipeline-name" style="color: var(--green);">SHIP</span>
                <span class="pipeline-arrow">&#8594;</span>
                <span class="pipeline-desc">Merge, deploy, or escalate</span>
            </div>
        </div>
    </section>

    <!-- Evidence -->
    <div class="evidence-line">
        <strong>@Model.TotalRuns</strong> pipeline runs · <strong>@Model.TotalIssues+</strong> issues resolved · <strong>@Model.TotalPrs+</strong> PRs merged · <strong>12m</strong> avg PRD-to-PR
    </div>

    <!-- Hard Boundary Stop -->
    @if (Model.BoundaryStop is not null)
    {
        <section aria-labelledby="boundary-heading">
            <div class="callout-card callout-boundary">
                <div class="callout-card-label">The system stopped here</div>
                <h2 id="boundary-heading" class="boundary-summary">@Model.BoundaryStop.Summary</h2>
                <div class="boundary-meta">
                    action: <span>@Model.BoundaryStop.RequestedAction</span><br />
                    outcome: <span>@Model.BoundaryStop.Outcome</span><br />
                    reason: @(Model.BoundaryStop.PolicyResult.Reason ?? "human review required")
                </div>
                <div class="callout-card-links">
                    <a href="/operator">See all decisions on /operator &#8594;</a>
                </div>
            </div>
        </section>
    }

    <!-- Latest Integration -->
    <section aria-labelledby="integration-heading">
        <div class="callout-card callout-integration">
            <div class="callout-card-label">New Integration</div>
            <h2 id="integration-heading" class="callout-card-title">meeting-to-main</h2>
            <div class="callout-card-desc">
                WorkIQ MCP &#8594; prd-to-prod. Meeting transcript in, merged PR out.
            </div>
            <div class="callout-card-links">
                <a href="https://github.com/samuelkahessay/meeting-to-main" target="_blank" rel="noopener noreferrer">Repo &#8599;</a>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <div class="landing-footer">
        <span>prd-to-prod — autonomous delivery pipeline. Built by Samuel Kahessay.</span>
        <div class="footer-links">
            <a href="https://github.com/samuelkahessay/prd-to-prod" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href="/operator">/operator</a>
            <a href="https://github.com/github/gh-aw" target="_blank" rel="noopener noreferrer">gh-aw</a>
        </div>
    </div>

</div>
