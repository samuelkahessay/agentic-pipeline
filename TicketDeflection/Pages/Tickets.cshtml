@page "/tickets"
@model TicketsModel
@{
    ViewData["Title"] = "Ticket Feed — Ticket Deflection Service";
    ViewData["NavTitle"] = "TICKET DEFLECTION SERVICE";
}

@section Styles {
<style>
    .log-entry {
        background: rgba(4, 10, 20, 0.7);
        border: 1px solid var(--border);
        border-left: 2px solid var(--dim);
        padding: 10px 14px;
        transition: border-left-color 0.15s;
    }
    .log-entry:hover { border-left-color: var(--accent); }
    .log-entry.status-resolved { border-left-color: var(--green); }
    .log-entry.status-escalated { border-left-color: var(--red); }
    .log-entry.status-classified { border-left-color: var(--accent); }
    .log-entry.status-matched { border-left-color: var(--amber); }
    .status-tag {
        font-family: var(--mono);
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 2px 8px;
        border: 1px solid;
        white-space: nowrap;
    }
    .tag-new { color: var(--dim); border-color: var(--border); background: transparent; }
    .tag-classified { color: var(--accent); border-color: rgba(0, 170, 255, 0.3); background: rgba(0, 170, 255, 0.06); }
    .tag-matched { color: var(--amber); border-color: rgba(245, 166, 35, 0.3); background: rgba(245, 166, 35, 0.06); }
</style>
}

<div class="max-w-5xl mx-auto px-4 py-10">

    <div class="flex items-end justify-between mb-8">
        <div>
            <div class="text-xs text-dim mb-2">// ticket pipeline — process log</div>
            <h1 class="font-sans text-3xl font-bold text-white">Ticket Feed</h1>
        </div>
        <button onclick="loadTickets()" class="page-btn" aria-label="Refresh ticket list">[ refresh ]</button>
    </div>

    <div class="text-xs text-dim mb-3 flex gap-6" aria-hidden="true">
        <span>PID</span>
        <span class="flex-1">TITLE / ROUTE</span>
        <span>STATUS</span>
    </div>
    <div style="border-top: 1px solid var(--border)" class="mb-2"></div>

    <div id="ticket-feed" class="flex flex-col gap-2" aria-live="polite" aria-label="Ticket feed">
        <div class="text-dim text-xs py-4">loading process log...</div>
    </div>

    <div class="flex items-center gap-3 mt-6">
        <button id="prevBtn" onclick="prevPage()" disabled class="page-btn" aria-label="Previous page">[ &lt; prev ]</button>
        <button id="nextBtn" onclick="nextPage()" class="page-btn" aria-label="Next page">[ next &gt; ]</button>
    </div>
</div>

@section Scripts {
<script>
    const LIMIT = 20;
    let offset = 0;

    const statusClass = {
        AutoResolved: 'status-resolved',
        Escalated: 'status-escalated',
        New: '',
        Classified: 'status-classified',
        Matched: 'status-matched'
    };

    const statusTag = {
        AutoResolved: '<span class="status-tag tag-resolved">AUTO_RESOLVED</span>',
        Escalated: '<span class="status-tag tag-escalated">ESCALATED</span>',
        New: '<span class="status-tag tag-new">NEW</span>',
        Classified: '<span class="status-tag tag-classified">CLASSIFIED</span>',
        Matched: '<span class="status-tag tag-matched">MATCHED</span>'
    };

    async function loadTickets() {
        const res = await fetch(`/api/metrics/tickets?limit=${LIMIT}&offset=${offset}`);
        const tickets = await res.json();
        const feed = document.getElementById('ticket-feed');

        if (tickets.length === 0) {
            feed.innerHTML = '<div class="text-dim text-xs py-4">no tickets found.</div>';
            document.getElementById('nextBtn').disabled = true;
            return;
        }

        feed.innerHTML = tickets.map((t, i) => {
            const pid = String(offset + i + 1).padStart(4, '0');
            const tag = statusTag[t.status] || statusTag['New'];
            const cls = statusClass[t.status] || '';
            const date = new Date(t.createdAt).toISOString().replace('T', ' ').slice(0, 19);
            return `
            <div class="log-entry ${cls}">
                <div class="flex items-center gap-4">
                    <span class="text-dim text-xs w-10 flex-shrink-0">#${pid}</span>
                    <div class="flex-1 min-w-0">
                        <div class="text-white text-sm font-bold truncate">${escapeHtml(t.title)}</div>
                        <div class="text-xs text-dim mt-1">${escapeHtml(t.category)} · ${escapeHtml(t.severity)} · <span style="color: rgba(0,170,255,0.4)">${date}</span></div>
                        ${t.resolution ? `<div class="text-xs mt-1" style="color: rgba(184,196,212,0.6)">&gt; ${escapeHtml(t.resolution)}</div>` : ''}
                    </div>
                    <div class="flex-shrink-0">${tag}</div>
                </div>
            </div>`;
        }).join('');

        document.getElementById('prevBtn').disabled = offset === 0;
        document.getElementById('nextBtn').disabled = tickets.length < LIMIT;
    }

    function prevPage() { offset = Math.max(0, offset - LIMIT); loadTickets(); }
    function nextPage() { offset += LIMIT; loadTickets(); }

    loadTickets();
</script>
}
