@page "/pipeline"
@model TicketDeflection.Pages.PipelineModel
@{
    ViewData["Title"] = "Pipeline Live";
    ViewData["NavTitle"] = "PIPELINE LIVE";
}

@section Styles {
<style>
    .warning {
        border: 1px solid rgba(245, 166, 35, 0.3);
        background: rgba(245, 166, 35, 0.08);
        color: var(--amber);
    }
    .stage-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
    }
    .stage-node {
        position: relative;
        min-height: 118px;
        padding: 16px;
    }
    .stage-node::after {
        content: "";
        position: absolute;
        top: 28px;
        right: -14px;
        width: 14px;
        border-top: 1px dashed rgba(0, 170, 255, 0.25);
    }
    .stage-node:last-child::after { display: none; }
    .stage-count {
        font-size: 2rem;
        line-height: 1;
        color: #e8edf5;
        margin-bottom: 8px;
    }
    .status-pill {
        display: inline-block;
        font-size: 0.65rem;
        padding: 3px 8px;
        border: 1px solid var(--border);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }
    .status-pill.active {
        color: var(--green);
        border-color: rgba(61, 220, 132, 0.3);
        background: rgba(61, 220, 132, 0.08);
    }
    .status-pill.idle {
        color: var(--dim);
        background: rgba(255, 255, 255, 0.03);
    }
    .chip {
        display: inline-block;
        margin-right: 8px;
        margin-bottom: 6px;
        padding: 2px 8px;
        border: 1px solid var(--border);
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }
    .chip-queue { color: var(--amber); }
    .chip-implementation { color: var(--accent); }
    .chip-review { color: #d4d8ff; }
    .chip-deploy { color: var(--green); }
    .chip-ops { color: #ff9bd7; }
    @@media (max-width: 900px) {
        .stage-grid { grid-template-columns: 1fr 1fr; }
        .stage-node::after { display: none; }
    }
    @@media (max-width: 640px) {
        .stage-grid { grid-template-columns: 1fr; }
    }
</style>
}

<div class="max-w-6xl mx-auto px-4 py-10">
    <div class="mb-8">
        <div class="text-xs text-dim mb-2 uppercase tracking-widest">// current repo state — actionable issues, prs, runs, deploys</div>
        <h1 class="font-sans text-3xl font-bold text-white mb-3">Live Pipeline Snapshot</h1>
        <div class="text-xs text-dim mb-3">live GitHub state, refreshes every 15 seconds</div>
        <p class="max-w-3xl text-sm leading-relaxed text-dim">
            This page polls the current GitHub control plane and renders the active software delivery loop as it exists now,
            not as a canned replay. Issue counts here refer to actionable pipeline work, not every open issue with the
            <code class="text-white">pipeline</code> label. The page is read-only and falls back cleanly when only unauthenticated
            GitHub API access is available.
        </p>
    </div>

    <div id="warningBox" class="warning p-4 mb-6 hidden" role="alert"></div>

    <div class="grid grid-cols-2 md:grid-cols-7 gap-4 mb-8" aria-label="Pipeline metrics">
        <div class="panel panel-top p-4">
            <div class="metric-lbl">actionable issues</div>
            <div id="metricIssues" class="metric-val" aria-live="polite">0</div>
        </div>
        <div class="panel panel-top p-4">
            <div class="metric-lbl">open prs</div>
            <div id="metricPrs" class="metric-val" aria-live="polite">0</div>
        </div>
        <div class="panel panel-top p-4">
            <div class="metric-lbl">active runs</div>
            <div id="metricRuns" class="metric-val" aria-live="polite">0</div>
        </div>
        <div class="panel panel-amber p-4">
            <div class="metric-lbl">deferred</div>
            <div id="metricDeferred" class="metric-val text-amber" aria-live="polite">0</div>
        </div>
        <div class="panel panel-red p-4">
            <div class="metric-lbl">repairs</div>
            <div id="metricRepairs" class="metric-val text-red" aria-live="polite">0</div>
        </div>
        <div class="panel panel-green p-4">
            <div class="metric-lbl">merge armed</div>
            <div id="metricMerge" class="metric-val text-green" aria-live="polite">0</div>
        </div>
        <div class="panel p-4 overflow-hidden">
            <div class="metric-lbl">mode</div>
            <div id="metricMode" class="text-white text-sm truncate">loading</div>
        </div>
    </div>

    <section class="panel p-5 mb-8" aria-labelledby="stage-heading">
        <div class="flex items-center justify-between mb-4">
            <div>
                <div class="text-xs text-dim uppercase tracking-widest mb-1">stage map</div>
                <h2 id="stage-heading" class="font-sans text-2xl font-bold text-white">Current pipeline flow</h2>
            </div>
            <div id="updatedAt" class="text-xs text-dim">updated: pending</div>
        </div>
        <div id="stageGrid" class="stage-grid" aria-live="polite"></div>
    </section>

    <div class="grid lg:grid-cols-3 gap-6">
        <section class="panel p-5" aria-labelledby="issue-heading">
            <div class="text-xs text-dim uppercase tracking-widest mb-2">open actionable pipeline issues</div>
            <h2 id="issue-heading" class="font-sans text-xl font-bold text-white mb-4">Issue queue</h2>
            <div id="issueList" class="text-sm text-dim" aria-live="polite">Loading issues...</div>
        </section>

        <section class="panel p-5" aria-labelledby="pr-heading">
            <div class="text-xs text-dim uppercase tracking-widest mb-2">open pipeline prs</div>
            <h2 id="pr-heading" class="font-sans text-xl font-bold text-white mb-4">Pull requests</h2>
            <div id="prList" class="text-sm text-dim" aria-live="polite">Loading pull requests...</div>
        </section>

        <section class="panel p-5" aria-labelledby="run-heading">
            <div class="text-xs text-dim uppercase tracking-widest mb-2">actions in progress</div>
            <h2 id="run-heading" class="font-sans text-xl font-bold text-white mb-4">Workflow runs</h2>
            <div id="runList" class="text-sm text-dim" aria-live="polite">Loading workflow runs...</div>
        </section>
    </div>
</div>

@section Scripts {
<script>
    const stageChipClass = {
        queue: 'chip chip-queue',
        implementation: 'chip chip-implementation',
        review: 'chip chip-review',
        deploy: 'chip chip-deploy',
        operations: 'chip chip-ops'
    };

    async function loadSnapshot() {
        const response = await fetch('/api/pipeline/live', { cache: 'no-store' });
        if (!response.ok) {
            throw new Error(`pipeline snapshot request failed: ${response.status}`);
        }
        return response.json();
    }

    function renderStages(stages) {
        const grid = document.getElementById('stageGrid');
        grid.innerHTML = stages.map(stage => `
            <div class="panel stage-node">
                <div class="metric-lbl">${escapeHtml(stage.label)}</div>
                <div class="stage-count">${stage.count}</div>
                <span class="status-pill ${stage.status === 'active' ? 'active' : 'idle'}">${escapeHtml(stage.status)}</span>
            </div>
        `).join('');
    }

    function renderIssues(issues) {
        const list = document.getElementById('issueList');
        if (!issues.length) {
            list.innerHTML = '<div class="text-dim">No active actionable pipeline issues.</div>';
            return;
        }
        list.innerHTML = issues.map(issue => `
            <div class="record">
                <div class="flex items-center justify-between gap-3">
                    <a class="text-accent hover:underline" href="${issue.url}" target="_blank" rel="noopener noreferrer">#${issue.number}</a>
                    <span class="chip chip-queue">${escapeHtml(issue.stageLabel)}</span>
                </div>
                <div class="text-white mt-2">${escapeHtml(issue.title)}</div>
                <div class="text-dim text-xs mt-2">labels: ${escapeHtml(issue.labels.join(', '))}</div>
                ${issue.linkedPullRequestUrl ? `<div class="text-dim text-xs mt-1">linked pr: <a class="text-accent hover:underline" href="${issue.linkedPullRequestUrl}" target="_blank" rel="noopener noreferrer">#${issue.linkedPullRequestNumber}</a></div>` : ''}
            </div>
        `).join('');
    }

    function renderPullRequests(prs) {
        const list = document.getElementById('prList');
        if (!prs.length) {
            list.innerHTML = '<div class="text-dim">No open pipeline pull requests.</div>';
            return;
        }
        list.innerHTML = prs.map(pr => `
            <div class="record">
                <div class="flex items-center justify-between gap-3">
                    <a class="text-accent hover:underline" href="${pr.url}" target="_blank" rel="noopener noreferrer">#${pr.number}</a>
                    <span class="chip chip-review">${escapeHtml(pr.stageLabel)}</span>
                </div>
                <div class="text-white mt-2">${escapeHtml(pr.title)}</div>
                <div class="text-dim text-xs mt-2">ci: ${escapeHtml(pr.ciState)} · review: ${escapeHtml(pr.reviewState)} · branch: ${escapeHtml(pr.headBranch)}</div>
                ${pr.linkedIssueNumber ? `<div class="text-dim text-xs mt-1">linked issue: #${pr.linkedIssueNumber}</div>` : ''}
            </div>
        `).join('');
    }

    function renderRuns(runs) {
        const list = document.getElementById('runList');
        if (!runs.length) {
            list.innerHTML = '<div class="text-dim">No workflow runs in progress.</div>';
            return;
        }
        list.innerHTML = runs.map(run => `
            <div class="record">
                <div class="flex items-center justify-between gap-3">
                    <a class="text-accent hover:underline" href="${run.url}" target="_blank" rel="noopener noreferrer">${escapeHtml(run.name)}</a>
                    <span class="${stageChipClass[run.stage] || 'chip'}">${escapeHtml(run.stageLabel)}</span>
                </div>
                <div class="text-dim text-xs mt-2">event: ${escapeHtml(run.event)} · branch: ${escapeHtml(run.headBranch || 'n/a')} · actor: ${escapeHtml(run.triggeringActor || 'n/a')}</div>
            </div>
        `).join('');
    }

    function renderWarnings(warnings, mode) {
        const box = document.getElementById('warningBox');
        const messages = [];
        if (mode === 'unauthenticated') {
            messages.push('GitHub access is unauthenticated. Live polling works for a demo, but rate limits are much lower.');
        }
        messages.push(...warnings);
        if (!messages.length) {
            box.classList.add('hidden');
            box.innerHTML = '';
            return;
        }
        box.classList.remove('hidden');
        box.innerHTML = messages.map(message => `<div>${escapeHtml(message)}</div>`).join('');
    }

    function renderSnapshot(snapshot) {
        document.getElementById('metricIssues').textContent = snapshot.summary.openIssues;
        document.getElementById('metricPrs').textContent = snapshot.summary.openPullRequests;
        document.getElementById('metricRuns').textContent = snapshot.summary.activeRuns;
        document.getElementById('metricDeferred').textContent = snapshot.summary.deferredIssues;
        document.getElementById('metricRepairs').textContent = snapshot.summary.repairLoops;
        document.getElementById('metricMerge').textContent = snapshot.summary.autoMergeArmed;
        document.getElementById('metricMode').textContent = snapshot.mode;
        document.getElementById('updatedAt').textContent = `updated: ${snapshot.updatedAtUtc}`;

        renderWarnings(snapshot.warnings, snapshot.mode);
        renderStages(snapshot.stages);
        renderIssues(snapshot.issues);
        renderPullRequests(snapshot.pullRequests);
        renderRuns(snapshot.activeRuns);
    }

    async function refresh() {
        try {
            const snapshot = await loadSnapshot();
            renderSnapshot(snapshot);
        } catch (error) {
            renderWarnings([error.message || 'Failed to load live pipeline snapshot.'], 'unauthenticated');
        }
    }

    refresh();
    window.setInterval(refresh, 15000);
</script>
}
